{
  "extends": "default",
  "meta": {
    "name": "codex",
    "version": "1.0.0",
    "description": "OpenAI Codex CLI agent (registry-managed)",
    "author": "lukehinds"
  },
  "groups": {
    "include": [
      "codex_macos",
      "user_caches_macos",
      "node_runtime",
      "rust_runtime",
      "python_runtime",
      "linux_sysfs_read",
      "nix_runtime",
      "git_config",
      "unlink_protection"
    ]
  },
  "security": {
    "signal_mode": "isolated",
    "capability_elevation": false
  },
  "filesystem": {
    "allow": [
      "$HOME/.codex",
      "$HOME/.agents",
      "$HOME/.config/nono/profile-drafts"
    ],
    "read": [
      "$HOME/.config/nono/packages",
      "$HOME/.config/nono/profiles"
    ]
  },
  "network": { "block": false },
  "workdir": { "access": "readwrite" },
  "open_urls": {
    "allow_origins": ["https://auth.openai.com"],
    "allow_localhost": true
  },
  "allow_launch_services": true,
  "undo": {
    "exclude_patterns": ["node_modules", ".next", "__pycache__", "target"],
    "exclude_globs": ["*.tmp.[0-9]*.[0-9]*"]
  },
  "interactive": true
}
