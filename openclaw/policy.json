{
  "extends": "default",
  "meta": {
    "name": "openclaw",
    "version": "1.0.0",
    "description": "OpenClaw AI agent — supports main and multi-agent instances with shared coordination bus",
    "author": "lukehinds"
  },
  "security": {
    "groups": [
      "node_runtime",
      "linux_runtime_state",
      "linux_sysfs_read",
      "git_config"
    ],
    "signal_mode": "isolated",
    "ipc_mode": "shared_memory_only"
  },
  "filesystem": {
    "allow": [
      "$HOME/.openclaw",
      "$HOME/.openclaw-agent1",
      "$HOME/.openclaw-agent2",
      "$HOME/.openclaw-agent3",
      "$HOME/.config/openclaw",
      "$HOME/.config/nono/profile-drafts",
      "$TMPDIR/openclaw-$UID"
    ],
    "read": [
      "$HOME/.config/nono/packages",
      "$HOME/.config/nono/profiles"
    ],
    "allow_file": [
      "$HOME/.openclaw.json"
    ]
  },
  "network": { "block": false },
  "workdir": { "access": "read" },
  "undo": {
    "exclude_patterns": ["node_modules", ".next"]
  },
  "interactive": false
}
